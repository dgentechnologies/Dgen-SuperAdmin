# SuperAdmin - public (client-safe)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=dgen-superadmin
NEXT_PUBLIC_FIREBASE_APP_ID=

# SuperAdmin - server only
FIREBASE_SUPERADMIN_PROJECT_ID=dgen-superadmin
FIREBASE_SUPERADMIN_CLIENT_EMAIL=
FIREBASE_SUPERADMIN_PRIVATE_KEY=
FIREBASE_SUPERADMIN_DATABASE_ID=(default)

# Website - server only
FIREBASE_WEBSITE_PROJECT_ID=dgen-superadmin
FIREBASE_WEBSITE_CLIENT_EMAIL=
FIREBASE_WEBSITE_PRIVATE_KEY=
FIREBASE_WEBSITE_STORAGE_BUCKET=
FIREBASE_WEBSITE_DATABASE_ID=website

# Access - server only
FIREBASE_ACCESS_PROJECT_ID=dgen-superadmin
FIREBASE_ACCESS_CLIENT_EMAIL=
FIREBASE_ACCESS_PRIVATE_KEY=
# Required only for the Realtime Database unlock feature.
# Format: https://<project-id>-default-rtdb.firebaseio.com
# Leave blank if Realtime Database / door unlock is not used.
FIREBASE_ACCESS_DATABASE_URL=
FIREBASE_ACCESS_DATABASE_ID=access

# Books - server only
FIREBASE_BOOKS_PROJECT_ID=dgen-superadmin
FIREBASE_BOOKS_CLIENT_EMAIL=
FIREBASE_BOOKS_PRIVATE_KEY=
FIREBASE_BOOKS_DATABASE_ID=books

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@dgentechnologies.com

# Auth
SESSION_COOKIE_NAME=dgen_superadmin_session
SESSION_EXPIRY_DAYS=5

# Comma-separated Firebase UIDs granted SuperAdmin access (env-based, no Firestore needed)
SUPERADMIN_UID=
