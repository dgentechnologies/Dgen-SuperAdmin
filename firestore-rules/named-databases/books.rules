// Firestore Security Rules for the "books" named database
// Project: dgen-superadmin | Database ID: books
// Deploy: firebase firestore:rules --database books --rules firestore-rules/named-databases/books.rules
//
// NOTE: Firebase Admin SDK (server-side) bypasses all rules below.
// These rules apply only to direct client-side SDK access.
// All reads and writes to this database go exclusively through the SuperAdmin
// server-side API routes — no client-side access is permitted.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny ALL client-side access. Only Firebase Admin SDK may read/write.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
