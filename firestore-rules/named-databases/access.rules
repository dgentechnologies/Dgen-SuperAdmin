// Firestore Security Rules for the "access" named database
// Project: dgen-superadmin | Database ID: access
// Deploy: firebase firestore:rules --database access --rules firestore-rules/named-databases/access.rules
//
// NOTE: Firebase Admin SDK (server-side) bypasses all rules below.
// These rules apply only to direct client-side SDK access.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Employees: authenticated employees can read their own and peer records
    match /employees/{id} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.status == 'active';
      allow write: if false;
    }

    // Access logs: authenticated users can create, no reads/updates/deletes
    match /access_logs/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
